# Discord bot token (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your-bot-token-here

# Optional: guild (server) ID to sync slash commands to instantly for testing.
# Leave empty to sync globally instead (can take up to an hour to propagate).
GUILD_ID=

# Default SSH credentials used for every device.
SSH_DEFAULT_USER=labuser
# Only one of the following is needed. Key auth is recommended.
SSH_DEFAULT_KEY_PATH=/home/labuser/.ssh/id_rsa
SSH_DEFAULT_PASSWORD=
